# Copy to .env for local dev (never commit real secrets).

DJANGO_SECRET_KEY=change-me-in-production
# Local: true | Railway: false
DJANGO_DEBUG=true

# Railway Postgres (set automatically when you add the Postgres plugin)
# DATABASE_URL=postgres://...

# Optional: comma-separated hostnames (Railway also uses RAILWAY_PUBLIC_DOMAIN)
# ALLOWED_HOSTS=

# Frontend origin(s) for CORS/CSRF — use your Next.js Railway URL(s), e.g.:
# CORS_ALLOWED_ORIGINS=https://your-app.up.railway.app
# CSRF_TRUSTED_ORIGINS=https://your-app.up.railway.app

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Cloudinary (uploads / FileField). Set in Railway Variables — do not commit secrets.
# Option A — single URL (recommended):
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Option B — separate vars:
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
